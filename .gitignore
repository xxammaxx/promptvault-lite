# =============================================================================
# PromptVault Lite — .gitignore
# =============================================================================

# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
target/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Logs
*.log

# OpenCode Session-Workspace (Sub-Installation mit eigenem node_modules)
.opencode/

# Tauri
src-tauri/gen/
src-tauri/Cargo.lock

# Test
coverage/
*.lcov

# Cache
.cache/
*.db
*.db-journal
*.db-wal

# WIP / Isolated Features (nicht für Release-Scope)
.tmp/
scripts/
site/

# Python cache
__pycache__/
.worktrees/

# Local Playwright/MCP runtime artifacts
.playwright-mcp/

# Local test evidence (screenshots, reports with private paths/content)
evidence/

# Playwright E2E Outputs (Privacy: contains screenshots, traces, videos)
test-results/
playwright-report/
playwright/.cache/
playwright/.auth/
*.trace.zip

# Playwright Visual Comparison Snapshots
**/__snapshots__/

# E2E configuration with private paths (NEVER commit)
tests/e2e/.env.local
tests/e2e/corpus-config.ts
playwright.config.local.ts
