.opencode/

# Tauri
src-tauri/gen/

# Test
coverage/
*.lcov

# Cache
.cache/
*.db
*.db-journal
*.db-wal

# WIP / Isolated Features (nicht für Release-Scope)
.tmp/
scripts/
site/

# Python cache
__pycache__/
